<UserControl x:Class="AstroRawOMatic.Nina.Plugin.PluginOptionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="600">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12" MaxWidth="580">

            <!-- Header -->
            <Border Background="#1a1f2e" CornerRadius="6" Padding="12,10" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="🔭  AstroRAW-o-Matic Bridge Plugin"
                               FontSize="15" FontWeight="Bold" Foreground="#63b3ed"/>
                    <TextBlock Text="Mostly harmless RAW conversion // v0.1.0"
                               FontSize="11" Foreground="#718096" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- CONVERTER -->
            <TextBlock Text="CONVERTER" FontWeight="Bold" FontSize="11"
                       Foreground="#63b3ed" LetterSpacing="1" Margin="0,0,0,6"/>
            <Separator Margin="0,0,0,10"/>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="CLI Pfad" VerticalAlignment="Center"
                           Foreground="#a0aec0" FontSize="12"/>
                <TextBox  Grid.Column="1" Text="{Binding CliPath, UpdateSourceTrigger=PropertyChanged}"
                          VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Button   Grid.Column="2" Content="..." Width="30"
                          Command="{Binding BrowseCliCommand}"
                          ToolTip="astroraw-o-matic.exe auswählen"/>
            </Grid>

            <!-- CLI status indicator -->
            <TextBlock Text="{Binding CliStatus}" FontSize="11"
                       Foreground="{Binding CliStatusColor}" Margin="120,0,0,12"/>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Header-Modus" VerticalAlignment="Center"
                           Foreground="#a0aec0" FontSize="12"/>
                <ComboBox  Grid.Column="1" SelectedValue="{Binding HeaderMode}"
                           SelectedValuePath="Content">
                    <ComboBoxItem Content="astro" IsSelected="True"/>
                    <ComboBoxItem Content="minimal"/>
                </ComboBox>
            </Grid>

            <!-- AUSGABE -->
            <TextBlock Text="AUSGABE" FontWeight="Bold" FontSize="11"
                       Foreground="#63b3ed" LetterSpacing="1" Margin="0,0,0,6"/>
            <Separator Margin="0,0,0,10"/>

            <CheckBox Content="FITS neben RAW speichern (gleicher Ordner)"
                      IsChecked="{Binding FitsNextToRaw}"
                      FontSize="12" Foreground="#a0aec0" Margin="0,0,0,6"/>

            <StackPanel Visibility="{Binding OutputFolderVisible}">
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="FITS-Zielordner" VerticalAlignment="Center"
                               Foreground="#a0aec0" FontSize="12"/>
                    <TextBox  Grid.Column="1" Text="{Binding OutputFolder}"
                              VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Button   Grid.Column="2" Content="..." Width="30"
                              Command="{Binding BrowseOutputCommand}"/>
                </Grid>
            </StackPanel>

            <CheckBox Content="RAW-Datei nach Konvertierung behalten (empfohlen)"
                      IsChecked="{Binding KeepRaw}"
                      FontSize="12" Foreground="#a0aec0" Margin="0,0,0,4"/>
            <CheckBox Content="session.json neben FITS speichern"
                      IsChecked="{Binding SaveMetadataJson}"
                      FontSize="12" Foreground="#a0aec0" Margin="0,0,0,16"/>

            <!-- BEOBACHTER / STANDORT -->
            <TextBlock Text="BEOBACHTER / STANDORT" FontWeight="Bold" FontSize="11"
                       Foreground="#63b3ed" LetterSpacing="1" Margin="0,0,0,6"/>
            <Separator Margin="0,0,0,10"/>

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Beobachter" VerticalAlignment="Center"
                           Foreground="#a0aec0" FontSize="12"/>
                <TextBox   Grid.Column="1" Text="{Binding Observer}"
                           VerticalAlignment="Center"/>
            </Grid>

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Observatorium" VerticalAlignment="Center"
                           Foreground="#a0aec0" FontSize="12"/>
                <TextBox   Grid.Column="1" Text="{Binding ObservatoryName}"
                           VerticalAlignment="Center"/>
            </Grid>

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Breitengrad" VerticalAlignment="Center"
                           Foreground="#a0aec0" FontSize="12"/>
                <TextBox   Grid.Column="1" Text="{Binding SiteLatitude}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"/>
                <TextBlock Grid.Column="3" Text="Längengrad" VerticalAlignment="Center"
                           Foreground="#a0aec0" FontSize="12" Margin="4,0,0,0"/>
                <TextBox   Grid.Column="4" Text="{Binding SiteLongitude}"
                           VerticalAlignment="Center"/>
            </Grid>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Höhe (m)" VerticalAlignment="Center"
                           Foreground="#a0aec0" FontSize="12"/>
                <TextBox   Grid.Column="1" Text="{Binding SiteElevation}"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- STATUS -->
            <TextBlock Text="STATUS" FontWeight="Bold" FontSize="11"
                       Foreground="#63b3ed" LetterSpacing="1" Margin="0,0,0,6"/>
            <Separator Margin="0,0,0,10"/>

            <CheckBox Content="Plugin aktiv // Automatisch konvertieren"
                      IsChecked="{Binding IsEnabled}"
                      FontSize="12" FontWeight="SemiBold" Foreground="#e2e8f0"
                      Margin="0,0,0,10"/>

            <!-- Recent conversions log -->
            <Border Background="#0f1117" CornerRadius="4" Padding="8" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Letzte Konvertierungen:" FontSize="11"
                               Foreground="#718096" Margin="0,0,0,4"/>
                    <ItemsControl ItemsSource="{Binding RecentConversions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="11"
                                           Foreground="#68d391" FontFamily="Consolas"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Button Content="Test-Konvertierung starten"
                    Command="{Binding TestConversionCommand}"
                    Width="200" HorizontalAlignment="Left"
                    Margin="0,0,0,20"/>

            <!-- Footer -->
            <Separator/>
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="🔭 Dark Matters Community // discord.gg/mvgC6aXY"
                           FontSize="10" Foreground="#4a5568" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="Author: Kai Linde"
                           FontSize="10" Foreground="#4a5568" VerticalAlignment="Center"/>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
