{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AstroRAW-o-Matic",
  "version": "0.2.0",
  "identifier": "de.ir-media-ad.astroraw-o-matic",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --prefix ../frontend",
    "beforeBuildCommand": "npm run build --prefix ../frontend"
  },
  "app": {
    "windows": [
      {
        "title": "AstroRAW-o-Matic // Mostly harmless RAW conversion",
        "width": 1100,
        "height": 1030,
        "minWidth": 900,
        "minHeight": 910,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
